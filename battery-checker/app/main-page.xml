<Page xmlns="http://schemas.nativescript.org/tns.xsd" navigatingTo="navigatingTo">
    <ActionBar title="Battery Checker" />
    <GridLayout rows="auto, auto, auto, *" columns="*" padding="20" rowSpacing="16">
        <Label row="0" text="{{ 'Battery:' + battery + '%' }}" 
            fontSize="28" fontWeight="bold" horizontalAlignment="center" />
        
        <StackLayout row="1" spacing="10">
            <Button text="Read battery (native)" tap="{{ onUpdateBattery }}"/>
            <Button text="Vibrate (native)" tap="{{ onVibrate }}"/>
            <Button text="Toast (native)" tap="{{ onToast }}"/>

        </StackLayout>

        <Label row="2" text="{{ log }}" textWrap="true" verticalAlignment="bottom" color="#666" />
    </GridLayout>
</Page>
