<Page xmlns="http://schemas.nativescript.org/tns.xsd" navigatingTo="navigatingTo">
    <ActionBar title="Todo App" icon="" />
    <StackLayout class="home">
        <TextField text="{{ newItem }}" hint="Add an item..." />
        <Button text="Add" tap="{{ addTodo }}" />
        <ListView items="{{ items }}">
            <ListView.itemTemplate>
                <GridLayout class="item-container" columns="36, *" rows="auto">
                    <Label row="0" col="0" text="ok" class="check"/>
                    <Label row="0" col="1" text="{{ title }}"  textWrap="true" class="title" />
                </GridLayout>
            </ListView.itemTemplate>
        </ListView>
    </StackLayout>
</Page>