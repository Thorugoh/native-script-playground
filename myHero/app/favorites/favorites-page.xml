<Page xmlns="http://schemas.nativescript.org/tns.xsd" navigatingTo="navigatingTo">
    <ActionBar title="Favorites" />

    <GridLayout rows="*">
        <Label text="No favorites yet." textAlignment="center" verticalAlignment="center"
               class="empty-hint" fontSize="16" visibility="{{ isEmpty ? 'visible' : 'collapsed' }}" />

        <ScrollView visibility="{{ isEmpty ? 'collapsed' : 'visible' }}">
            <Repeater items="{{ heroes }}">
                <Repeater.itemsLayout>
                    <WrapLayout orientation="horizontal" />
                </Repeater.itemsLayout>
                <Repeater.itemTemplate>
                    <StackLayout width="50%" padding="6">
                        <StackLayout class="card" padding="8">
                            <GridLayout rows="*" columns="*" height="150">
                                <Image src="{{ imageUrl }}" stretch="aspectFill" borderRadius="6" tap="onHeroTap" />
                                <Label text="♥" class="heart" fontSize="28"
                                       horizontalAlignment="right" verticalAlignment="bottom" padding="6"
                                       tap="removeFavorite" />
                            </GridLayout>
                            <Label class="hero-name" text="{{ name }}" fontSize="14" textAlignment="center"
                                   textWrap="true" marginTop="8" tap="onHeroTap" />
                        </StackLayout>
                    </StackLayout>
                </Repeater.itemTemplate>
            </Repeater>
        </ScrollView>
    </GridLayout>
</Page>
