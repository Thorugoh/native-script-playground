<Page xmlns="http://schemas.nativescript.org/tns.xsd" navigatingTo="navigatingTo">
    <ActionBar title="{{ hero.name }}" />

    <ScrollView>
        <StackLayout padding="20">
            <StackLayout class="card" padding="6" width="212" horizontalAlignment="center">
                <Image src="{{ hero.imageUrl }}" width="200" height="200" stretch="aspectFill" borderRadius="6" />
            </StackLayout>
            <Label class="hero-name" text="{{ hero.name }}" fontSize="26" textAlignment="center" marginTop="16" />
            <Label class="hero-sub" text="{{ hero.description }}" textWrap="true" fontSize="15" textAlignment="center" marginTop="8" />

            <Button text="Share" tap="onShare" class="-primary" marginTop="16" />

            <Label class="section-title" text="Biography" fontSize="18" marginTop="24" marginBottom="8" />

            <GridLayout columns="auto, *" rows="auto, auto, auto, auto, auto, auto" class="card" padding="14">
                <Label col="0" row="0" class="bio-key" text="Full name" marginRight="12" marginBottom="8" />
                <Label col="1" row="0" class="bio-value" text="{{ hero.biography.fullName }}" textWrap="true" marginBottom="8" />

                <Label col="0" row="1" class="bio-key" text="Alter egos" marginRight="12" marginBottom="8" />
                <Label col="1" row="1" class="bio-value" text="{{ hero.biography.alterEgos }}" textWrap="true" marginBottom="8" />

                <Label col="0" row="2" class="bio-key" text="Aliases" marginRight="12" marginBottom="8" />
                <Label col="1" row="2" class="bio-value" text="{{ hero.biography.aliases }}" textWrap="true" marginBottom="8" />

                <Label col="0" row="3" class="bio-key" text="Place of birth" marginRight="12" marginBottom="8" />
                <Label col="1" row="3" class="bio-value" text="{{ hero.biography.placeOfBirth }}" textWrap="true" marginBottom="8" />

                <Label col="0" row="4" class="bio-key" text="First appearance" marginRight="12" marginBottom="8" />
                <Label col="1" row="4" class="bio-value" text="{{ hero.biography.firstAppearance }}" textWrap="true" marginBottom="8" />

                <Label col="0" row="5" class="bio-key" text="Publisher" marginRight="12" />
                <Label col="1" row="5" class="bio-value" text="{{ hero.biography.publisher }}" textWrap="true" />
            </GridLayout>
        </StackLayout>
    </ScrollView>
</Page>
