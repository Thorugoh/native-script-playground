<Page xmlns="http://schemas.nativescript.org/tns.xsd" navigatingTo="navigatingTo">
    <ActionBar title="My Heroes" icon="" />

    <GridLayout rows="auto, auto, *" class="p-10">
        <SearchBar row="0" hint="Search a Hero" text="{{ search }}" submit="{{ onSearch }}" />

        <ActivityIndicator row="1" busy="{{ loading }}" visibility="{{ loading ? 'visible' : 'collapsed' }}" />

        <Label row="1" text="{{ error }}" color="red" textWrap="true"
               visibility="{{ error ? 'visible' : 'collapsed' }}" />

        <ListView row="2" items="{{ heroes }}" itemTap="{{ onHeroTap }}">
            <ListView.itemTemplate>
                <GridLayout columns="auto, *" rows="auto, auto" padding="10" class="bg-secondary">
                    <Image col="0" rowSpan="2" src="{{ imageUrl }}" width="60" height="60" stretch="aspectFill" />
                    <Label col="1" row="0" text="{{ name }}" fontWeight="700" fontSize="16" margin="0 10" />
                    <Label col="1" row="1" text="{{ description }}" textWrap="true" fontSize="12" margin="0 10" />
                </GridLayout>
            </ListView.itemTemplate>
        </ListView>
    </GridLayout>
</Page>
